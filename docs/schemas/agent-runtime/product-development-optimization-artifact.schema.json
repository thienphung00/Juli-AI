{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://juli.ai/schemas/agent-runtime/product-development-optimization-artifact.schema.json",
  "title": "Product Development Optimization Artifact",
  "description": "Meta Agent occasional output routed to Architect Agent backlog for process and architecture improvements.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "artifactType",
    "id",
    "sourceIssueIds",
    "detectedPattern",
    "rootCauseCategory",
    "planningSignal",
    "architectureSignal",
    "decompositionSignal",
    "reviewSignal",
    "recommendedBacklogItem",
    "requiresADR",
    "requiresPRDUpdate",
    "requiresIssueTemplateUpdate",
    "priority",
    "evidenceArtifacts",
    "acceptedByArchitect"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "artifactType": {
      "const": "product_development_optimization"
    },
    "id": {
      "type": "string",
      "pattern": "^product-development-[a-z0-9-]+$",
      "description": "Stable identifier, e.g. product-development-unclear-decomposition-2026-06"
    },
    "sourceIssueIds": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "integer", "minimum": 1 }
    },
    "sourceBenchmarkRunIds": {
      "type": "array",
      "items": { "type": "string" }
    },
    "detectedPattern": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable description of the recurring pattern."
    },
    "rootCauseCategory": {
      "type": "string",
      "enum": [
        "context_underloaded",
        "context_overloaded",
        "wrong_executor_domain",
        "insufficient_tdd_evidence",
        "review_gap",
        "validation_failure",
        "tool_overuse",
        "phase_loop",
        "artifact_incomplete",
        "architecture_unclear"
      ]
    },
    "planningSignal": {
      "type": "string",
      "description": "Evidence from planning phase or source docs."
    },
    "architectureSignal": {
      "type": "string",
      "description": "Evidence of boundary violations or unclear ownership."
    },
    "decompositionSignal": {
      "type": "string",
      "description": "Evidence of weak issue decomposition or missing acceptance criteria."
    },
    "reviewSignal": {
      "type": "string",
      "description": "Evidence from repeated review failures in a module or domain."
    },
    "recommendedBacklogItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "suggestedLabels": {
          "type": "array",
          "items": { "type": "string" }
        },
        "affectedModules": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "requiresADR": { "type": "boolean" },
    "requiresPRDUpdate": { "type": "boolean" },
    "requiresIssueTemplateUpdate": { "type": "boolean" },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "evidenceArtifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "description": "Paths to implementation, review, validation, or harness optimization artifacts."
      }
    },
    "acceptedByArchitect": {
      "type": "string",
      "enum": ["pending", "accepted", "rejected"]
    },
    "architectNotes": { "type": "string" },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
