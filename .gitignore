node_modules/
.pnpm-store/
.turbo/

__pycache__/
*.pyc
.pytest_cache/
.coverage
.coverage.*
coverage/
apps/dashboard/coverage/
*.egg-info/
dist/
build/
.env
.env.*
.DS_Store

# Agent runtime state (local resumption only — not source control)
.agent-state/

# Local git worktrees (parallel issue isolation — not source control)
.worktrees/

# Large runtime telemetry (small JSON artifacts under agent-runtime/artifacts/ are committed per ADR-003)
agent-runtime/artifacts/runtime/raw/
agent-runtime/artifacts/runtime/logs/

# Serialized ML model artifacts (runtime output — not source control)
/models/

# Python virtual environment
.venv/

# Accidental venv dirs from mistyped `python -m venv <word>` (e.g. `#`, `already`)
#/
already/
exists/
if/
skip/

# Next.js build output
.next/

# Local SQLite test databases
*.db

# Local Alembic pg_dump backups (default ~/.juli-backups; optional repo-local dir)
.backups/

# AWS Secrets Manager credentials / generated env files (VPS-only runtime
# state — infra/scripts/fetch-secrets.sh writes these outside the repo at
# /etc/juli/*, but ignore any local copies too in case someone stages one
# here for testing).
aws-credentials
infra/scripts/aws-credentials
infra/deploy/*.env
infra/scripts/env/*.local
releases/

# Read-only vendor reference material pulled for porting research (e.g.
# hermes-agent context/caching source study). Never a dependency, never
# built, never committed as part of Juli AI's own tree.
/reference/

# Workflow prompt cache *artifacts* stay local (per-machine fingerprints / issue bodies).
# Gate scripts, slice-routing, schemas, templates, and prompt-caching skill are tracked
# so Meta can auto-ensure caches without a human reminder (meta_prepare_executor.py).
agent-runtime/artifacts/workflow-cache/
agent-runtime/artifacts/grill-cache/

# Playwright (apps/demo exit-gate)
apps/demo/test-results/
apps/demo/playwright-report/
apps/demo/blob-report/
