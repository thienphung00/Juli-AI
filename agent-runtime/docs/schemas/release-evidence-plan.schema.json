{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://juli.ai/schemas/agent-runtime/release-evidence-plan.schema.json",
  "title": "Release Evidence Plan",
  "description": "Required on child workflow cache issueLoadProfile.releaseEvidencePlan when publicRelease is true (ADR-035 / PRD #500).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planId",
    "affectedPublicSurfaces",
    "candidateVerificationJourney",
    "staticAssetChecks",
    "migrationCompatibility",
    "rollbackAssertion",
    "requiredArtifacts",
    "acceptanceCommands",
    "doNotInfer"
  ],
  "properties": {
    "planId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable id e.g. rep-<issueId>-<shortHash>; copied into implementation artifact."
    },
    "affectedPublicSurfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "candidateVerificationJourney": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "mode",
        "stableTrafficPercent",
        "candidatePublicTrafficPercent",
        "restrictedRoute",
        "syntheticShopRequired",
        "workersDisabledOnCandidate",
        "journeys"
      ],
      "properties": {
        "mode": { "const": "candidate_verification" },
        "stableTrafficPercent": { "type": "integer", "minimum": 0, "maximum": 100 },
        "candidatePublicTrafficPercent": { "const": 0 },
        "restrictedRoute": { "type": "string", "minLength": 1 },
        "syntheticShopRequired": { "type": "boolean" },
        "workersDisabledOnCandidate": { "type": "boolean" },
        "apiSideEffectsInScope": { "type": "boolean" },
        "journeys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "entryUrl", "assertions"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "entryUrl": { "type": "string", "minLength": 1 },
              "assertions": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    },
    "staticAssetChecks": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "required",
        "htmlRoutes",
        "discoverFromHtml",
        "assetTypes",
        "failOnMissing",
        "failOnNon200"
      ],
      "properties": {
        "required": { "type": "boolean" },
        "htmlRoutes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "discoverFromHtml": { "type": "boolean" },
        "assetTypes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "failOnMissing": { "type": "boolean" },
        "failOnNon200": { "type": "boolean" }
      }
    },
    "migrationCompatibility": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schemaChangeInScope",
        "expandContractOnly",
        "stableAndCandidateCompatible",
        "destructiveMigrationAllowed",
        "notes"
      ],
      "properties": {
        "schemaChangeInScope": { "type": "boolean" },
        "expandContractOnly": { "type": "boolean" },
        "stableAndCandidateCompatible": { "type": "boolean" },
        "destructiveMigrationAllowed": { "const": false },
        "notes": { "type": "string", "minLength": 1 }
      }
    },
    "rollbackAssertion": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "preCutoverFailureBehavior",
        "postCutoverFailureBehavior",
        "retainedStableRequired",
        "automatic"
      ],
      "properties": {
        "preCutoverFailureBehavior": { "type": "string", "minLength": 1 },
        "postCutoverFailureBehavior": { "type": "string", "minLength": 1 },
        "retainedStableRequired": { "type": "boolean" },
        "automatic": { "type": "boolean" }
      }
    },
    "requiredArtifacts": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "implementation",
        "intentReview",
        "review",
        "validation",
        "releaseMetadataHonest"
      ],
      "properties": {
        "implementation": { "type": "boolean" },
        "intentReview": { "type": "boolean" },
        "review": { "type": "boolean" },
        "validation": { "type": "boolean" },
        "releaseMetadataHonest": { "type": "boolean" }
      }
    },
    "acceptanceCommands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "doNotInfer": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
