# App Review backend env template — api.app-juli.com
#
# Copy to ~/Juli-AI-v2/.env on the VPS and fill in real values there.
# NEVER commit real values. Secrets live outside source control (VPS env file
# or a secret manager). Placeholders below are intentionally non-functional.

# Required at startup (FastAPI lifespan opens the DB engine).
#
# Use the Session pooler URI on IPv4-only VPS hosts (most cloud VPS). Direct
# db.*.supabase.co hosts are IPv6-only and will fail with "Connection refused".
# Supabase Dashboard → Connect → Session mode → URI (port 5432).
DATABASE_URL=postgresql://postgres.REPLACE_PROJECT_REF:REPLACE_PASSWORD@aws-0-REPLACE_REGION.pooler.supabase.com:5432/postgres

# Direct connection URI — used for migrations (alembic).
DATABASE_DIRECT_URL=postgresql://postgres.REPLACE_PROJECT_REF:REPLACE_PASSWORD@db.REPLACE_PROJECT_REF.supabase.co:5432/postgres

# Supabase project configuration.
SUPABASE_URL=https://REPLACE_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# JWT validation for protected API routes.
SUPABASE_JWT_SECRET=REPLACE_ME

# TikTok OAuth + webhook signature verification (Partner Center sandbox app for
# review). Also required for POST /webhooks/tiktok (Issue #381) — the webhook
# ingress route is mounted on this same juli-api process, not a separate service.
TIKTOK_APP_KEY=REPLACE_ME
TIKTOK_APP_SECRET=REPLACE_ME
# Optional — CI integration tests (issue #366); never commit real values.
# TIKTOK_SANDBOX_AUTH_CODE=REPLACE_ME
# TIKTOK_SANDBOX_REFRESH_TOKEN=REPLACE_ME
# Preferred key for encrypting persisted TikTok OAuth tokens.
TIKTOK_TOKEN_ENCRYPTION_KEY=REPLACE_ME

# Temporary TikTok debug routes (GET /debug/tiktok/verify-connection).
# Set to 1 during App Review; leave unset or 0 in production.
# ENABLE_TIKTOK_DEBUG=1
#
# OAuth token persistence requires base tables — on first deploy run:
#   cd ~/Juli-AI-v2 && .venv/bin/alembic upgrade 001

# CORS: allow the review frontend origin to call the API.
CORS_ALLOW_ORIGINS=https://app-juli.com

# App Review skips Redis/workers/cron and a separate webhook deploy target — do
# not set REDIS_URL unless a required startup path forces it (then split the
# dependency into a new issue). TikTok webhook ingress (#381) is a route on this
# same process; it needs no additional service, port, or env var beyond the
# TikTok credentials above.
