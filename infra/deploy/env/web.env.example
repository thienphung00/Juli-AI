# App Review frontend env template — app-juli.com
#
# Copy to /opt/juli/web/.env.production on the VPS and fill in real values there.
# NEVER commit real values. NEXT_PUBLIC_* values are baked at build time.

# Public API base URL the frontend calls (must be the HTTPS API domain).
NEXT_PUBLIC_API_URL=https://api.app-juli.com
